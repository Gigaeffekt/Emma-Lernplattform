<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /aela/

  # Share page routing: /aela/share/{uuid} -> /aela/share/index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^share/(.+)/?$ share/index.html [QSA,L]

  # Other rules
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
</IfModule>
